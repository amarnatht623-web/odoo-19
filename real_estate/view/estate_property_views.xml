<odoo>
    <record id="test_model_action" model="ir.actions.act_window">
        <field name="name">Test action1</field>
        <field name="res_model">real.estate</field>
        <field name="view_mode">list,form</field>
    </record>




    <record id="new1" model="ir.ui.view">
        <field name="name">real.estate</field>
        <field name="model">real.estate</field>
        <field name="arch" type="xml">
            <form string="form">
                <sheet>
                    <h1>
                    <group>
                            <field name="name" ></field>

                    </group>
                    </h1>
                    <group>

                        <group>
                            <field name="Date_availability"></field>
                            <field name="selling_price"></field>
                            <field name="expected_price"></field>
                            <field name="status"/>
                            <field name="property_type_id"/>

                            <field name="active"></field>
                        </group>
                        <group>
                             <field name="post_code"></field>
                            <field name="facades"></field>
                            <field name="property_tags_id" widget="many2many_tags"/>
                            <field name="best_offers"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="description">
                            <group>
                            <field name="description"></field>
                            </group>
                        </page>
                        <page string="offers">
                                <field name="offers_id">
                                     <list>
                                    <field name="price"/>
                                         <field name="status"/>
                                    <field name="partner_id"/>
                                         <field name="validity"/>
                                         <field name = "date_deadline"/>

                                </list>

                                </field>



                        </page>
                        <page string="other info">
                        <group>
                            <group>
                                <field name="Gardens"></field>
                                <field name="garden_area"></field>
                                <field name="garden_orientation"/>
                                <field name="living_area"/>
                                <field name="bedrooms"/>
                                <field name="total_area"/>


                            </group>
                            <group>
                                <field name="partner_id"/>
                                <field name="user_id"/>
                            </group>
                        </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="new2" model="ir.ui.view">
        <field name="name">real.estate</field>
        <field name="model">real.estate</field>
        <field name="arch" type="xml">

                         <list string="Test">
                             <field name="name"></field>
                             <field name="post_code"></field>
                             <field name="selling_price"></field>
                         </list>

        </field>

    </record>
    <record id="new3" model="ir.ui.view">
        <field name="name">real.estate</field>
        <field name="model">real.estate</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter name="states" domain="['|','|','|',('status','=','New'),('status','=','outgoing'),('status','=','done'),('status','=','cancel')]"/>
                <filter name="name" context="{'group_by':'name'}"/>

            </search>

        </field>
    </record>
</odoo>