<odoo>
    <data noupdate="1">
        <record id="email_template_project" model="mail.template">
            <field name="name">Project</field>
            <field name="model_id" ref="project_budget_tracking.model_project_project"/>
            <field name="subject">Notification: {{ object.name }}</field>
            <field name="email_from">{{ object.company_id.email_formatted }}</field>
            <field name="email_to">{{ object.user_id.email }}</field>
            <field name="body_html" type="html">
                <div>
                    <p>Hello <t t-out="object.user_id.name"/>,Warning,budget exceeded 80%</p>
                </div>
            </field>
        </record>
    </data>
</odoo>
