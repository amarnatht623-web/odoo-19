<odoo>
    <record id="department_model_action" model="ir.actions.act_window">
        <field name="name">Department</field>
        <field name="res_model">hospital.department</field>
        <field name="view_mode">list,form</field>
    </record>
     <record id="department_model_action1" model="ir.ui.view">
        <field name="name">Department</field>
        <field name="model">hospital.department</field>
        <field name="arch" type="xml">
                         <list string="Department">
                             <field name="name"/>
                         </list>
        </field>
     </record>
    <record id="department_model_action2" model="ir.ui.view">
        <field name="name">Department</field>
        <field name="model">hospital.department</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <group>
                    <h1>
                        <group>
                            <field name="name" placeholder="Eg.Department name" colspan="8" style="width: 100%"/>
                        </group>
                    </h1>
                    </group>
                        <notebook>
                            <page string="doctor information">
                                <group>
                                    <field name="doctor_ids" widget="many2many_tags"/>
                                </group>
                            </page>
                        </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>