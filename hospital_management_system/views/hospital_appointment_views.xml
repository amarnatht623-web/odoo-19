<odoo>
    <record id="appointment_model_action" model="ir.actions.act_window">
        <field name="name">Appointment</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>
     <record id="appointment_model_action_list" model="ir.ui.view">
        <field name="name">patient</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
                         <list string="Patients">
                             <field name="ref_no"/>
                         </list>
        </field>
     </record>
    <record id="appointment_model_action2" model="ir.ui.view">
        <field name="name">Appointment</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form string="appointment">
                <header>
                    <button name="Schedule_confirm" string="Schedule Appointment" class="btn-primary" type="object" invisible="state != 'Draft'" />
                    <button name="start_consultation" string="Start Consultation" class="btn-primary" type="object" invisible="state != 'Scheduled'"/>
                    <button name="complete_consultation" string="Complete Consultation" class="btn-primary" type="object" invisible="state != 'Consultation'"/>
                    <button name="cancel_appointment" string="Cancel Appointment" class="btn-primary" type="object" />
                    <field name="state" widget="statusbar" options="{'clickable':'1'}"
                               statusbar_visible="Draft,Scheduled,Consultation,Completed,Cancelled"/>
                </header>
                <sheet>
                    <group>
                    <h1>
                        <group>
                            <field name="ref_no" placeholder="Eg. Appointment" colspan="8" style="width: 100%"/>
                        </group>
                    </h1>
                    </group>
                        <notebook>
                            <page string="Patient information">
                                <group>
                                    <field name="patient_id"/>
                                    <field name="department_id"/>
                                    <field name="doctor_id"  domain="[('id', 'in',dept_doctor_ids),('is_doctor','=',True),('is_available','=',True)]"/>
                                    <field name="appointment_datetime"/>
                                    <field name="consultation_fee"/>
                                    <field name="symptoms"/>
                                    <field name="diagnosis"/>
                                    <field name="medicine_total"/>
                                    <field name="total_bill"/>
                                </group>
                            </page>
                            <page string="priscription  lines" >
                                <field name="prescription_ids" >
                                    <list editable="bottom">
                                        <field name="appointment_id"/>
                                        <field name="product_id"/>
                                        <field name="dosage"/>
                                        <field name="days"/>
                                        <field name="quantity" width="100px"/>
                                        <field name="unit_price"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>