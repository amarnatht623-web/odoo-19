<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="prescription_model_action4" model="ir.actions.act_window">
        <field name="name">hospital prescription line</field>
        <field name="res_model">hospital.prescription.line</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="prescription" model="ir.ui.view">
        <field name="name">hospital prescription line</field>
        <field name="model">hospital.prescription.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="appointment_id" required="True"/>
                <field name="product_id"/>
                <field name="dosage"/>
                <field name="days"/>
                <field name="quantity"/>
                <field name="unit_price"/>

            </list>
        </field>
    </record>
</odoo>