<odoo>
   <record id="view_book_borrow_report_form" model="ir.ui.view">
       <field name="name">book.borrow.report</field>
       <field name="model">book.borrow.report</field>
       <field name="arch" type="xml">
           <form string="Report">
               <group>
                   <field name="member_id"/>
                   <field name="from_date"/>
                   <field name="to_date" />
                   <field name="book_name_id" />
                   <field name="book_genres_id"/>
                   <field name="sorting_option"/>
                   <field name="sorted_by" invisible="sorting_option != 'issued_date' and sorting_option != 'due_date'"/>
               </group>
           <footer>
               <button string="pdf report"
                       name="confirm_pdf_report"
                       type="object"
                       class="btn-primary"/>
               <button string="xlsx report"
                       name="confirm_xlsx_report"
                       type="object"
                       class="btn-primary"/>
               <button string="Cancel"
                       class="btn-secondary"
                       special="cancel"/>
           </footer>
           </form>
       </field>
   </record>
    <record id="action_book_borrow_report" model="ir.actions.act_window">
        <field name="name">book borrow report</field>
        <field name="res_model">book.borrow.report</field>
        <field name="target">new</field>
        <field name="view_mode">form</field>
    </record>

</odoo>