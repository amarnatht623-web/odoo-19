<odoo>
    <record id="patient_model_action" model="ir.actions.act_window">
        <field name="name">Patient</field>
        <field name="res_model">hospital.patient</field>
        <field name="view_mode">list,form</field>
    </record>
     <record id="patient_model_action_list" model="ir.ui.view">
        <field name="name">patient</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">

                         <list string="Patients">
                             <field name="name"/>
                             <field name="gender"/>
                         </list>
        </field>
     </record>
    <record id="patient_model_action2" model="ir.ui.view">
        <field name="name">Patient</field>
        <field name="model">hospital.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <header>
                     <field name="draft" widget="statusbar" options="{'clickable':'1'}"
                               statusbar_visible="Draft,Active,Discharge"/>
                </header>
                <sheet>
                    <group>
                    <h1>
                        <group>
                            <field name="name" placeholder="Eg.Patient name" colspan="8" style="width: 100%"/>
                        </group>
                    </h1>
                    </group>
                        <notebook>
                            <page string="Patient information">
                                <group>
                                    <field name="date_of_birth"/>
                                    <field name="age"/>
                                    <field name="gender"/>
                                    <field name="blood_group"/>
                                    <field name="mobile"/>
                                    <field name="department_id"/>
                                    <field name="appointment_count"/>
                                    <field name="treatment_progress"/>
                                </group>
                            </page>
                            <page string="appointment">
                                <field name="appointment_ids"/>
                            </page>
                        </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>