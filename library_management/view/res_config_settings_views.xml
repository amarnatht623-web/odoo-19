<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.sale</field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="books" data-string="Books" name="library_management">
                    <block title="books">
                        <setting id="books"
                                 title="books"
                                 string="borrowing days"
                                 help="borrowing days for books.">
                            <field name="borrowing_book_days"/>
                        </setting>
                        <setting id="books1"
                                 title="books"
                                 string="reminder days"
                                 help="Reminder days before a book is due.">
                            <field name="reminder_days"/>
                        </setting>
                        <setting id="books2"
                                 title="books"
                                 string="hourly penalty"
                                 help="Penalty charged for each hour a book is overdue">
                            <field name="hourly_penalty"/>
                        </setting>
                        <setting
                                 id="books3"
                                 title="books"
                                 string="maximum books"
                                 help="maximum books allowed for each members">
                           <field name="max_book"/>
                        </setting>
                        <setting
                                 id="books4"
                                 title="books"
                                 string="maximum late returns"
                                 help="maximum late returns are allowed for each members">
                           <field name="max_late_returns"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
    <record id="action_sale_config_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_id" ref="res_config_settings_view_form"/>
        <field name="view_mode">form</field>
        <field name="context">{'module' : 'library_management', 'bin_size': False}</field>
    </record>
</odoo>
