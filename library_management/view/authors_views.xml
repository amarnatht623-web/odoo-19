<odoo>
        <record id="authors_model_action" model="ir.actions.act_window">
        <field name="name">authors</field>
        <field name="res_model">authors</field>
        <field name="view_mode">list,form</field>
        </record>

    <record id="authors_model_action1" model="ir.ui.view">
        <field name="name">Authors</field>
        <field name="model">authors</field>
        <field name="arch" type="xml">

                         <list string="authors">
                             <field name="name"/>
                             <field name="authors_book_ids"/>
                         </list>
        </field>
    </record>

        <record id="authors_model_action2" model="ir.ui.view">
        <field name="name">Authors</field>
        <field name="model">authors</field>
        <field name="arch" type="xml">
            <form string="Authors">
                <sheet>
                        <h1>
                            <group>
                            <field name="name"/>
                            </group>
                        </h1>
                    <group>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page name="books">
                            <field name="authors_book_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>



        </field>
    </record>


</odoo>