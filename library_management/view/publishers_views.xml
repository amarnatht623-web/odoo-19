<odoo>
    <record id="publishers_model_action" model="ir.actions.act_window">
        <field name="name">publishers</field>
        <field name="res_model">publishers</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="publishers_model_action1" model="ir.ui.view">
        <field name="name">Publishers</field>
        <field name="model">publishers</field>
        <field name="arch" type="xml">

            <list string="publishers">
                <field name="name"/>
            </list>

        </field>
    </record>

    <record id="publishers_model_action2" model="ir.ui.view">
        <field name="name">Publishers</field>
        <field name="model">publishers</field>
        <field name="arch" type="xml">

            <form string="publishers">
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                    <group>
                        <span>
                            <span> Address </span>
                        </span>
                        <div class="o_address_format">
                                <field name="street" placeholder="Street..." class="o_address_street"/>
                                <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="city" placeholder="City" class="o_address_city"/>
                                <field name="state_id" class="o_address_state" placeholder="State"
                                       options='{"no_open": True}'/>
                                <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="country_id" placeholder="Country" class="o_address_country"
                                       options='{"no_open": True, "no_create": True}'/>

                        </div>
                    </group>

                    <notebook>
                        <page string="books">
                            <field name="published_book_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>

        </field>
    </record>


</odoo>