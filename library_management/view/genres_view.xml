<odoo>
    <record id="genres_model_action" model="ir.actions.act_window">
        <field name="name">genres</field>
        <field name="res_model">genres</field>
        <field name="view_mode">list,form</field>
    </record>


    <record id="genres_model_action1" model="ir.ui.view">
        <field name="name">genres</field>
        <field name="model">genres</field>
        <field name="arch" type="xml">

            <list string="genres">
                <field name="name"/>
                <field name="book_genres_ids"/>
            </list>
        </field>
    </record>

    <record id="genres_model_action2" model="ir.ui.view">
        <field name="name">genres</field>
        <field name="model">genres</field>
        <field name="arch" type="xml">

            <form string="genres">
                <sheet>
                    <h1>
                        <group>
                            <field name="name"/>
                        </group>
                    </h1>
                    <notebook>
                        <page string="books">
                            <field name="book_genres_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>