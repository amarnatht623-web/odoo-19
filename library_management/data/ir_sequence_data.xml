<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <data noupdate="1">
       <record id="ir_sequence_library_book" model="ir.sequence">
           <field name="name">reference no</field>
           <field name="code">books</field>
           <field name="prefix">LIB</field>
           <field name="padding">5</field>
           <field name="number_next">1</field>
           <field name="number_increment">1</field>
           <field name="company_id" eval="False"/>
       </record>
   </data>

    <data noupdate="1">
        <record id="ir_sequence_library_checkout" model="ir.sequence">
           <field name="name">reference id</field>
           <field name="code">checkout</field>
           <field name="prefix">OUT</field>
           <field name="padding">5</field>
           <field name="number_next">1</field>
           <field name="number_increment">1</field>
           <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
